{
    "comments": {
        "lineComment": {"comment": "//"},
        "blockComment": ["/*","*/"]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "onEnterRules": [
        {
            //  /* [ENTER]
            "beforeText": "^\\s*/\\*\\*(?:.(?!\\*\\/))*?\\s*$",
            "afterText": "^\\s*\\*/*$",
            "action": {
                "indent": "indentOutdent",
                "appendText": " * "
            }
        },
        {
            //   * line 1 [ENTER]
            "beforeText": "^\\s*\\*(?!\\/)([^\\*]|\\*(?!\\/))*$",
            "action": {
                "indent": "none",
                "appendText": "* "
            }
        },
        {
            //   * [ENTER] */
            "beforeText": "^\\s*\\*\\s*$",
            "afterText": "^\\s*\\*/\\s*$",
            "action": {
                "indent": "none",
                "appendText": "* "
            }
        },
        {
            "beforeText": "^\\s*\\*/$",
            "action": {
                "indent": "outdent",
                "removeText": 1
            }
        }
    ],
    "autoClosingPairs": [
        { "open": "/**", "close": " */", "notIn": ["string"] },
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "'", "close": "'", "notIn": ["string", "comment"] },
        { "open": "\"", "close": "\"", "notIn": ["string"] },
        { "open": "s'", "close": "'", "notIn": ["string", "comment"] },
        { "open": "s\"", "close": "\"", "notIn": ["string"] },
        { "open": "n'", "close": "'", "notIn": ["string", "comment"] },
        { "open": "n\"", "close": "\"", "notIn": ["string"] }
    ],
    "autoCloseBefore": ";:.,=}])>` \n\t",
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["'", "'"],
        ["\"", "\""]
    ],
    "folding": {
        "markers": {
            "start": "^.\/\/@region\\b",
            "end": "^.*\/\/@endregion\\b"
        }
    },
    "wordPattern": "(-?\\d*\\.\\d\\w*)|(%?[^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)",
    "indentationRules": {
        "increaseIndentPattern": "^((?!\\/\\/).)*(\\{[^}\"'`]*|\\([^)\"'`]*|\\[[^\\]\"'`]*)$",
        "decreaseIndentPattern": "^((?!.*?\\/\\*).*\\*/)?\\s*[\\)\\}\\]].*$",
        "unIndentedLinePattern": "^(\\t|[ ])*[ ]\\*[^/]*\\*/\\s*$|^(\\t|[ ])*[ ]\\*/\\s*$|^(\\t|[ ])*[ ]\\*([ ]([^\\*]|\\*(?!/))*)?$"
    }
}